# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed.
#
# Usage:
#   cp .env.example .env
#   docker compose -f docker/postgres/docker-compose.yml --env-file .env up -d

# --- Postgres (local Docker container) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-something-strong
POSTGRES_DB=ga40db
POSTGRES_PORT=5432

# --- pgAdmin (local Docker container) ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me
PGADMIN_PORT=5050

# --- App connection string (wired up in slice #1) ---
# DATABASE_URL=postgresql://postgres:change-me-to-something-strong@localhost:5432/ga40db
