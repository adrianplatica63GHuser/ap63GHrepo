# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed.
#
# Usage:
#   cp .env.example .env
#   docker compose -f docker/postgres/docker-compose.yml --env-file .env up -d

# --- Postgres (local Docker container) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-something-strong
POSTGRES_DB=ga40db
POSTGRES_PORT=5432

# --- pgAdmin (local Docker container) ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me
PGADMIN_PORT=5050

# --- App connection string ---
# Local dev (Docker Postgres — only DATABASE_URL needed):
# DATABASE_URL=postgresql://postgres:change-me-to-something-strong@localhost:5432/ga40db

# Supabase (set both; see drizzle.config.ts for why two strings are needed):
#   DIRECT_URL  — direct connection, port 5432; used only by drizzle-kit migrations
#   DATABASE_URL — pooled connection, port 6543; used by the running app (and by Vercel)
#
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Google Maps API key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY

# Google Maps Map ID (required for AdvancedMarker / draggable corners)
# Create one at: https://console.cloud.google.com/google/maps-apis/studio/maps
# Leave unset in dev to use the official "DEMO_MAP_ID" placeholder (no setup needed)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID

